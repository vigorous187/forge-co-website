---
/** TODO: Build out full styling in Phase 1 */
interface Props {
  value: string;
  label: string;
  prefix?: string;
  suffix?: string;
}

const { value, label, prefix, suffix } = Astro.props;
---

<div class="text-center">
  <p class="font-display text-4xl font-bold text-brand-heading">
    {prefix && <span class="text-brand-secondary">{prefix}</span>}
    {value}
    {suffix && <span class="text-brand-secondary">{suffix}</span>}
  </p>
  <p class="mt-2 text-sm text-brand-muted">{label}</p>
</div>
