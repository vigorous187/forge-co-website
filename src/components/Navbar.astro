---
const industries = [
  { name: "Contractors", slug: "contractors" },
  { name: "Restaurants", slug: "restaurants" },
  { name: "Realtors", slug: "realtors" },
  { name: "Auto Shops", slug: "auto-shops" },
  { name: "Dental", slug: "dental" },
  { name: "Legal", slug: "legal" },
  { name: "Landscaping", slug: "landscaping" },
  { name: "Cleaning", slug: "cleaning" },
];

const col1 = industries.slice(0, 4);
const col2 = industries.slice(4);
---

<nav
  class="fixed top-0 left-0 right-0 z-50 h-[72px] flex items-center border-b border-[#2d2d2d]"
  style="background: rgba(13,13,13,0.92); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);"
>
  <div class="max-w-7xl mx-auto w-full px-6 flex items-center justify-between">
    <!-- Logo -->
    <a
      href="/"
      class="text-[#f3f4f6] text-3xl tracking-widest hover:text-[#c41230] transition-colors"
      style="font-family: 'Bebas Neue', sans-serif;"
    >
      FORGE
    </a>

    <!-- Desktop Nav -->
    <ul class="hidden md:flex items-center gap-8 text-sm font-medium text-[#6b7280]">
      <li>
        <a href="/services" class="hover:text-[#f3f4f6] transition-colors">Services</a>
      </li>

      <!-- Industries Dropdown -->
      <li class="relative group">
        <button
          class="flex items-center gap-1 hover:text-[#f3f4f6] transition-colors cursor-pointer"
          aria-haspopup="true"
          aria-expanded="false"
        >
          Industries
          <svg
            class="w-3 h-3 transition-transform group-hover:rotate-180"
            fill="none"
            stroke="currentColor"
            viewBox="0 0 24 24"
          >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
          </svg>
        </button>

        <!-- Mega Dropdown -->
        <div
          class="absolute top-full left-1/2 -translate-x-1/2 mt-4 w-72 bg-[#1a1a1a] border border-[#2d2d2d] opacity-0 invisible group-hover:opacity-100 group-hover:visible transition-all duration-200"
          style="transform: translateX(-50%);"
        >
          <div class="p-5 grid grid-cols-2 gap-x-6 gap-y-2">
            <div class="space-y-2">
              {col1.map((ind) => (
                <a
                  href={`/industries/${ind.slug}/`}
                  class="block text-sm text-[#6b7280] hover:text-[#f3f4f6] hover:translate-x-1 transition-all py-1"
                >
                  {ind.name}
                </a>
              ))}
            </div>
            <div class="space-y-2">
              {col2.map((ind) => (
                <a
                  href={`/industries/${ind.slug}/`}
                  class="block text-sm text-[#6b7280] hover:text-[#f3f4f6] hover:translate-x-1 transition-all py-1"
                >
                  {ind.name}
                </a>
              ))}
            </div>
          </div>
        </div>
      </li>

      <li>
        <a href="/case-studies" class="hover:text-[#f3f4f6] transition-colors">Case Studies</a>
      </li>
      <li>
        <a href="/about" class="hover:text-[#f3f4f6] transition-colors">About</a>
      </li>
      <li>
        <a href="/blog" class="hover:text-[#f3f4f6] transition-colors">Blog</a>
      </li>
    </ul>

    <!-- CTA + Hamburger -->
    <div class="flex items-center gap-4">
      <a
        href="/contact"
        class="hidden md:inline-flex items-center px-5 py-2.5 bg-[#c41230] text-white text-sm font-semibold hover:bg-[#a00e26] transition-colors tracking-wide"
      >
        BOOK A CALL
      </a>

      <!-- Hamburger (mobile) -->
      <button
        id="hamburger-btn"
        class="md:hidden flex flex-col gap-1.5 p-2"
        aria-label="Open menu"
        aria-expanded="false"
      >
        <span class="block w-6 h-0.5 bg-[#f3f4f6] transition-all" id="ham-line-1"></span>
        <span class="block w-6 h-0.5 bg-[#f3f4f6] transition-all" id="ham-line-2"></span>
        <span class="block w-6 h-0.5 bg-[#f3f4f6] transition-all" id="ham-line-3"></span>
      </button>
    </div>
  </div>
</nav>

<!-- Mobile Menu Overlay -->
<div
  id="mobile-menu"
  class="fixed inset-0 z-40 bg-[#0d0d0d] flex-col pt-[72px] px-6 pb-8 overflow-y-auto"
  aria-hidden="true"
>
  <ul class="mt-8 space-y-1 text-lg font-medium">
    <li>
      <a href="/services" class="block py-3 border-b border-[#2d2d2d] text-[#f3f4f6] hover:text-[#c41230] transition-colors">
        Services
      </a>
    </li>

    <!-- Industries Accordion -->
    <li class="border-b border-[#2d2d2d]">
      <button
        id="accordion-btn"
        class="w-full flex items-center justify-between py-3 text-[#f3f4f6] hover:text-[#c41230] transition-colors"
        aria-expanded="false"
      >
        Industries
        <svg
          id="accordion-arrow"
          class="w-4 h-4 transition-transform"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"></path>
        </svg>
      </button>
      <div id="accordion-content" class="accordion-content pb-3">
        <div class="grid grid-cols-2 gap-2 pt-2">
          {industries.map((ind) => (
            <a
              href={`/industries/${ind.slug}/`}
              class="text-sm text-[#6b7280] hover:text-[#f3f4f6] py-1.5 transition-colors"
            >
              {ind.name}
            </a>
          ))}
        </div>
      </div>
    </li>

    <li>
      <a href="/case-studies" class="block py-3 border-b border-[#2d2d2d] text-[#f3f4f6] hover:text-[#c41230] transition-colors">
        Case Studies
      </a>
    </li>
    <li>
      <a href="/about" class="block py-3 border-b border-[#2d2d2d] text-[#f3f4f6] hover:text-[#c41230] transition-colors">
        About
      </a>
    </li>
    <li>
      <a href="/blog" class="block py-3 border-b border-[#2d2d2d] text-[#f3f4f6] hover:text-[#c41230] transition-colors">
        Blog
      </a>
    </li>
  </ul>

  <div class="mt-8">
    <a
      href="/contact"
      class="block w-full text-center px-5 py-4 bg-[#c41230] text-white font-semibold tracking-wide hover:bg-[#a00e26] transition-colors"
    >
      BOOK A CALL
    </a>
  </div>
</div>

<script>
  const hamburgerBtn = document.getElementById("hamburger-btn");
  const mobileMenu = document.getElementById("mobile-menu");
  const line1 = document.getElementById("ham-line-1");
  const line2 = document.getElementById("ham-line-2");
  const line3 = document.getElementById("ham-line-3");
  const accordionBtn = document.getElementById("accordion-btn");
  const accordionContent = document.getElementById("accordion-content");
  const accordionArrow = document.getElementById("accordion-arrow");

  let menuOpen = false;
  let accordionOpen = false;

  hamburgerBtn?.addEventListener("click", () => {
    menuOpen = !menuOpen;
    if (mobileMenu) {
      if (menuOpen) {
        mobileMenu.classList.add("open");
        mobileMenu.removeAttribute("aria-hidden");
        hamburgerBtn.setAttribute("aria-expanded", "true");
        // Animate to X
        if (line1) line1.style.transform = "translateY(8px) rotate(45deg)";
        if (line2) line2.style.opacity = "0";
        if (line3) line3.style.transform = "translateY(-8px) rotate(-45deg)";
      } else {
        mobileMenu.classList.remove("open");
        mobileMenu.setAttribute("aria-hidden", "true");
        hamburgerBtn.setAttribute("aria-expanded", "false");
        if (line1) line1.style.transform = "";
        if (line2) line2.style.opacity = "";
        if (line3) line3.style.transform = "";
      }
    }
  });

  accordionBtn?.addEventListener("click", () => {
    accordionOpen = !accordionOpen;
    if (accordionContent) {
      if (accordionOpen) {
        accordionContent.classList.add("open");
        accordionBtn.setAttribute("aria-expanded", "true");
        if (accordionArrow) accordionArrow.style.transform = "rotate(180deg)";
      } else {
        accordionContent.classList.remove("open");
        accordionBtn.setAttribute("aria-expanded", "false");
        if (accordionArrow) accordionArrow.style.transform = "";
      }
    }
  });
</script>
