---
const quickLinks = [
  { label: 'Services', href: '/services/' },
  { label: 'Case Studies', href: '/case-studies/' },
  { label: 'Blog', href: '/blog/' },
  { label: 'About', href: '/about/' },
];

const serviceLinks = [
  { label: 'SearchForge', href: '/services/search-forge/' },
  { label: 'ContentForge', href: '/services/content-forge/' },
  { label: 'Web Design', href: '/services/web-design/' },
  { label: 'Growth Audit', href: '/growth-audit/' },
];

const socialLinks = [
  { label: 'Instagram', href: 'https://instagram.com/forgegrowth', icon: 'instagram' },
  { label: 'TikTok', href: 'https://tiktok.com/@forgegrowth', icon: 'tiktok' },
  { label: 'LinkedIn', href: 'https://linkedin.com/company/forge-growth', icon: 'linkedin' },
];
---

<footer class="bg-brand-primary text-brand-white/80">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <!-- Brand Column -->
      <div>
        <a href="/" class="inline-block">
          <img src="/assets/images/forge-logo-dark.png" alt="Forge-Co." class="h-12 w-auto" />
        </a>
        <p class="mt-4 text-sm leading-relaxed text-brand-white/60">
          Toronto's growth systems agency for websites, visibility, and content.
        </p>
        <p class="mt-2 text-xs text-brand-white/40">
          Serving Toronto, Mississauga, Burlington, Hamilton, Oakville & Brampton
        </p>
      </div>

      <!-- Quick Links -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-brand-white">Quick Links</h3>
        <ul class="mt-4 space-y-2">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm hover:text-brand-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-brand-white">Services</h3>
        <ul class="mt-4 space-y-2">
          {serviceLinks.map((link) => (
            <li>
              <a href={link.href} class="text-sm hover:text-brand-white transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="text-sm font-semibold uppercase tracking-wider text-brand-white">Contact</h3>
        <ul class="mt-4 space-y-2 text-sm">
          <li>Toronto, ON</li>
          <li>
            <a href="mailto:hello@forge-co.ca" class="hover:text-brand-white transition-colors">
              hello@forge-co.ca
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Social Links -->
    <div class="mt-12 flex items-center gap-6 border-t border-white/10 pt-8">
      {socialLinks.map((social) => (
        <a
          href={social.href}
          target="_blank"
          rel="noopener noreferrer"
          class="text-brand-white/60 hover:text-brand-white transition-colors"
          aria-label={social.label}
        >
          {social.icon === 'instagram' && (
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
            </svg>
          )}
          {social.icon === 'tiktok' && (
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z" />
            </svg>
          )}
          {social.icon === 'linkedin' && (
            <svg class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
            </svg>
          )}
        </a>
      ))}
    </div>

    <!-- Bottom Bar -->
    <div class="mt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-brand-white/40">
      <p>&copy; 2026 Forge Growth Co.</p>
      <div class="flex items-center gap-4">
        <a href="/privacy/" class="hover:text-brand-white/60 transition-colors">Privacy</a>
        <a href="/terms/" class="hover:text-brand-white/60 transition-colors">Terms</a>
      </div>
    </div>
  </div>
</footer>
