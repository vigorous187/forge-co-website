---
const currentYear = new Date().getFullYear();
---

<footer class="bg-[#0d0d0d] border-t border-[#2d2d2d] mt-0">
  <div class="max-w-7xl mx-auto px-6 py-16">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-10">
      <!-- Company -->
      <div>
        <a
          href="/"
          class="text-[#f3f4f6] text-2xl tracking-widest hover:text-[#c41230] transition-colors block mb-4"
          style="font-family: 'Bebas Neue', sans-serif;"
        >
          FORGE
        </a>
        <p class="text-[#6b7280] text-sm leading-relaxed mb-6">
          Digital presence agency for local businesses in Toronto and the GTA.
        </p>
        <!-- Social -->
        <div class="flex gap-4">
          <a
            href="#"
            aria-label="Instagram"
            class="w-9 h-9 border border-[#2d2d2d] flex items-center justify-center text-[#6b7280] hover:text-[#f3f4f6] hover:border-[#6b7280] transition-all"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
          </a>
          <a
            href="#"
            aria-label="TikTok"
            class="w-9 h-9 border border-[#2d2d2d] flex items-center justify-center text-[#6b7280] hover:text-[#f3f4f6] hover:border-[#6b7280] transition-all"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z"/>
            </svg>
          </a>
          <a
            href="#"
            aria-label="LinkedIn"
            class="w-9 h-9 border border-[#2d2d2d] flex items-center justify-center text-[#6b7280] hover:text-[#f3f4f6] hover:border-[#6b7280] transition-all"
          >
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Industries -->
      <div>
        <h4
          class="text-[#f3f4f6] text-sm font-semibold tracking-widest mb-5 uppercase"
          style="font-family: 'Bebas Neue', sans-serif; letter-spacing: 0.15em;"
        >
          Industries
        </h4>
        <ul class="space-y-2.5">
          {[
            ["Contractors", "contractors"],
            ["Restaurants", "restaurants"],
            ["Realtors", "realtors"],
            ["Auto Shops", "auto-shops"],
            ["Dental", "dental"],
            ["Legal", "legal"],
            ["Landscaping", "landscaping"],
            ["Cleaning", "cleaning"],
          ].map(([name, slug]) => (
            <li>
              <a
                href={`/industries/${slug}/`}
                class="text-sm text-[#6b7280] hover:text-[#f3f4f6] transition-colors"
              >
                {name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Resources -->
      <div>
        <h4
          class="text-[#f3f4f6] text-sm font-semibold tracking-widest mb-5 uppercase"
          style="font-family: 'Bebas Neue', sans-serif; letter-spacing: 0.15em;"
        >
          Resources
        </h4>
        <ul class="space-y-2.5">
          {[
            ["Case Studies", "/case-studies"],
            ["Blog", "/blog"],
            ["SEO Guide", "/resources/seo-guide"],
            ["Review Guide", "/resources/review-guide"],
            ["GBP Checklist", "/resources/gbp-checklist"],
          ].map(([name, href]) => (
            <li>
              <a
                href={href}
                class="text-sm text-[#6b7280] hover:text-[#f3f4f6] transition-colors"
              >
                {name}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h4
          class="text-[#f3f4f6] text-sm font-semibold tracking-widest mb-5 uppercase"
          style="font-family: 'Bebas Neue', sans-serif; letter-spacing: 0.15em;"
        >
          Contact
        </h4>
        <ul class="space-y-3">
          <li class="text-sm text-[#6b7280]">Toronto, Ontario</li>
          <li>
            <a
              href="mailto:hello@forge-co.ca"
              class="text-sm text-[#6b7280] hover:text-[#f3f4f6] transition-colors"
            >
              hello@forge-co.ca
            </a>
          </li>
          <li class="pt-2">
            <a
              href="/contact"
              class="inline-flex items-center px-5 py-2.5 bg-[#c41230] text-white text-sm font-semibold hover:bg-[#a00e26] transition-colors tracking-wide"
            >
              BOOK A CALL
            </a>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Bottom Bar -->
  <div class="border-t border-[#2d2d2d]">
    <div class="max-w-7xl mx-auto px-6 py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="text-xs text-[#6b7280]">
        &copy; {currentYear} Forge. Digital presence agency, Toronto.
      </p>
      <div class="flex gap-6">
        <a href="/privacy" class="text-xs text-[#6b7280] hover:text-[#f3f4f6] transition-colors">
          Privacy Policy
        </a>
        <a href="/terms" class="text-xs text-[#6b7280] hover:text-[#f3f4f6] transition-colors">
          Terms of Service
        </a>
      </div>
    </div>
  </div>
</footer>
