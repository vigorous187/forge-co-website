---
interface Props {
  name: string;
  subtitle: string;
  description: string;
  href: string;
  icon?: string;
  image?: string;
}

const { name, subtitle, description, href, image } = Astro.props;
---

<a href={href} class="block bg-brand-card rounded-xl overflow-hidden border border-brand-border card-hover">
  {image && (
    <div class="relative h-40 overflow-hidden">
      <img
        src={image}
        alt={name}
        class="w-full h-full object-cover"
        loading="lazy"
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent"></div>
    </div>
  )}
  <div class="p-6">
    <h3 class="font-display text-xl font-bold text-brand-heading">{name}</h3>
    <p class="text-sm text-brand-secondary font-medium mt-1">{subtitle}</p>
    <p class="mt-3 text-sm text-brand-muted leading-relaxed">{description}</p>
    <span class="mt-4 inline-block text-sm font-semibold text-brand-primary">
      Learn more &rarr;
    </span>
  </div>
</a>
