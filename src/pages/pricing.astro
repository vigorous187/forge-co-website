---
import Layout from '../layouts/Layout.astro';
import BreadcrumbNav from '../components/BreadcrumbNav.astro';
import CTABanner from '../components/CTABanner.astro';

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Engagement Options',
    description: 'How Forge engagements are structured for local operators.',
    url: 'https://forge-co.ca/pricing/',
  },
];
---

<Layout
  title="Engagement Options | Forge"
  description="How Forge structures growth engagements for local operators."
  schema={schema}
  noindex={true}
>
  <section class="bg-brand-primary section-hero">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <BreadcrumbNav items={[{ label: 'Home', href: '/' }, { label: 'Engagement Options' }]} />
      <h1 class="mt-6 font-display text-4xl sm:text-5xl lg:text-6xl font-800 text-brand-white leading-tight text-shadow-forge">
        Engagement Options
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-brand-white/70 max-w-2xl mx-auto">
        We share engagement details during a strategy call so recommendations match your goals, market, and operating model.
      </p>
      <div class="mt-10">
        <a href="/contact/" class="btn-secondary text-base px-8 py-4">Book a Strategy Call</a>
      </div>
    </div>
  </section>

  <section class="section-standard bg-brand-bg">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-2xl mx-auto text-center mb-10">
        <h2 class="font-display text-2xl sm:text-3xl font-bold text-brand-heading">Choose the right entry point for execution.</h2>
        <p class="mt-3 text-brand-muted">Every engagement starts with diagnosis, clear priorities, and accountable implementation.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="rounded-xl border border-brand-border bg-brand-card p-7">
          <h3 class="font-display text-xl font-bold text-brand-heading">Diagnose the real growth baseline.</h3>
          <p class="mt-3 text-brand-muted">We audit visibility, conversion, and retention to identify priority bottlenecks.</p>
        </div>
        <div class="rounded-xl border border-brand-border bg-brand-card p-7">
          <h3 class="font-display text-xl font-bold text-brand-heading">Prioritize actions by measurable impact.</h3>
          <p class="mt-3 text-brand-muted">You get a practical action roadmap sequenced by impact and execution effort.</p>
        </div>
        <div class="rounded-xl border border-brand-border bg-brand-card p-7">
          <h3 class="font-display text-xl font-bold text-brand-heading">Execute with monthly accountability.</h3>
          <p class="mt-3 text-brand-muted">We implement the growth system with monthly reporting and clear accountability.</p>
        </div>
      </div>
    </div>
  </section>

  <CTABanner
    headline="Need a growth plan tailored to your business?"
    description="Start with a strategy call or lead with a Growth Audit. We'll map the right next step."
    primaryCTA={{ text: 'Book a Strategy Call', href: '/contact/' }}
    secondaryCTA={{ text: 'Get Your Growth Audit', href: '/growth-audit/' }}
  />
</Layout>
