---
import Layout from '../layouts/Layout.astro';
import ServiceCard from '../components/ServiceCard.astro';
import MetricCallout from '../components/MetricCallout.astro';
import CaseStudyCard from '../components/CaseStudyCard.astro';
import BlogCard from '../components/BlogCard.astro';

const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Forge',
  url: 'https://forge-co.ca',
  description: 'Growth systems agency for GTA operators, with a dedicated restaurant growth branch',
  potentialAction: {
    '@type': 'SearchAction',
    target: 'https://forge-co.ca/search/?q={search_term_string}',
    'query-input': 'required name=search_term_string',
  },
};
---

<Layout
  title="Forge — Growth Systems for GTA Operators"
  description="Forge builds connected growth systems for local operators. Website development, SEO, and content execution, plus a dedicated restaurant branch through Toronto Restaurant Growth."
  schema={[websiteSchema]}
>

  <!-- ============================================ -->
  <!-- HERO                                         -->
  <!-- ============================================ -->
  <section id="hero" class="hero-section">
    <div class="hero-bg-gradient"></div>
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">
        <!-- Text Column -->
        <div class="text-center lg:text-left">
          <p class="hero-qualifier">Growth systems for local operators across the GTA</p>
          <h1 class="font-display text-4xl sm:text-5xl lg:text-5xl xl:text-6xl font-800 text-brand-white leading-[1.08] tracking-tight text-shadow-forge">
            Build Once. Grow Everywhere.
          </h1>
          <p class="mt-6 text-lg sm:text-xl text-brand-white/70 max-w-xl mx-auto lg:mx-0 leading-relaxed">
            Forge is the master growth brand for websites, visibility, and content systems. Toronto Restaurant Growth runs as our dedicated restaurant branch.
          </p>
          <div class="mt-10 flex flex-col sm:flex-row items-center lg:items-start justify-center lg:justify-start gap-4">
            <a href="/growth-audit/" class="btn-secondary text-base px-8 py-4 shadow-lg shadow-brand-secondary/20">
              Get Your Growth Audit
            </a>
            <a href="#system" class="hero-secondary-cta">
              See How It Works
              <svg class="ml-2 h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
              </svg>
            </a>
          </div>
        </div>
        <!-- Image Column -->
        <div class="hero-image-wrapper">
          <div class="relative">
            <img
              src="/assets/images/hero-food-plating.jpg"
              alt="Chef plating food with precision in a restaurant kitchen"
              class="hero-image"
              width="640"
              height="480"
            />
            <div class="hero-result-chip">
              <svg class="h-3.5 w-3.5 text-brand-secondary" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 10.5L12 3m0 0l7.5 7.5M12 3v18" />
              </svg>
              <span>+340% Maps Visibility (Crab Boil)</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- SELECTED CLIENT WORK STRIP                   -->
  <!-- ============================================ -->
  <section id="clients" class="client-strip">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <p class="text-center text-xs font-semibold uppercase tracking-widest text-brand-muted mb-6">Selected Client Work</p>
      <div class="flex items-center justify-center gap-6 sm:gap-8 flex-wrap">
        <div class="client-logo-slot">
          <img src="/assets/images/crabboil-logo.jpg" alt="Crab Boil" class="client-logo" loading="lazy" width="160" height="80" />
        </div>
        <div class="client-logo-slot">
          <img src="https://www.mtcrenovations.ca/assets/img/logo/logo.png" alt="MTC Renovations" class="client-logo" loading="lazy" width="160" height="80" />
        </div>
        <div class="client-logo-slot">
          <img src="https://michaelthehomebuyer.ca/assets/img/logo/logo-full.webp" alt="Michael The Home Buyer" class="client-logo" loading="lazy" width="408" height="140" />
        </div>
        <div class="client-logo-slot">
          <img src="https://ibuyuglyhouses.ca/assets/img/logo/logo-optimized.svg" alt="I Buy Ugly Houses" class="client-logo" loading="lazy" width="204" height="70" />
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- WHY FORGE                                    -->
  <!-- ============================================ -->
  <section id="trust" class="trust-strip">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <p class="text-center text-sm font-medium text-brand-muted uppercase tracking-wider mb-4">
        Built for local operators, with dedicated restaurant growth through TRG
      </p>
      <h2 class="text-center font-display text-xl font-bold text-brand-heading mb-10">Why Forge</h2>
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-6 lg:gap-8">
        <div class="why-forge-card">
          <div class="trust-icon">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 8.25v-1.5m0 1.5c-1.355 0-2.697.056-4.024.166C6.845 8.51 6 9.473 6 10.608v2.513m6-4.871c1.355 0 2.697.056 4.024.166C17.155 8.51 18 9.473 18 10.608v2.513M15 8.25v-1.5m-6 1.5v-1.5m12 9.75l-1.5.75a3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0 3.354 3.354 0 00-3 0 3.354 3.354 0 01-3 0L3 16.5m15-3.379a48.474 48.474 0 00-6-.371c-2.032 0-4.034.126-6 .371m12 0c.39.049.777.102 1.163.16 1.07.16 1.837 1.094 1.837 2.175v5.169c0 .621-.504 1.125-1.125 1.125H4.125A1.125 1.125 0 013 20.625v-5.17c0-1.08.768-2.014 1.837-2.174A47.78 47.78 0 016 13.12M12.265 3.11a.375.375 0 11-.53 0L12 2.845l.265.265zm-3 0a.375.375 0 11-.53 0L9 2.845l.265.265zm6 0a.375.375 0 11-.53 0L15 2.845l.265.265z" />
            </svg>
          </div>
          <span class="trust-label">Multi-Vertical Core</span>
          <p class="text-xs text-brand-muted mt-1 leading-snug">One growth system adapted per vertical</p>
        </div>
        <div class="why-forge-card">
          <div class="trust-icon">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5M9 11.25v1.5M12 9v3.75m3-6v6" />
            </svg>
          </div>
          <span class="trust-label">Full Growth System</span>
          <p class="text-xs text-brand-muted mt-1 leading-snug">SEO, content, web, reputation -- connected</p>
        </div>
        <div class="why-forge-card">
          <div class="trust-icon">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18.75a60.07 60.07 0 0115.797 2.101c.727.198 1.453-.342 1.453-1.096V18.75M3.75 4.5v.75A.75.75 0 013 6h-.75m0 0v-.375c0-.621.504-1.125 1.125-1.125H20.25M2.25 6v9m18-10.5v.75c0 .414.336.75.75.75h.75m-1.5-1.5h.375c.621 0 1.125.504 1.125 1.125v9.75c0 .621-.504 1.125-1.125 1.125h-.375m1.5-1.5H21a.75.75 0 00-.75.75v.75m0 0H3.75m0 0h-.375a1.125 1.125 0 01-1.125-1.125V15m1.5 1.5v-.75A.75.75 0 003 15h-.75M15 10.5a3 3 0 11-6 0 3 3 0 016 0zm3 0h.008v.008H18V10.5zm-12 0h.008v.008H6V10.5z" />
            </svg>
          </div>
          <span class="trust-label">Clear Execution Scope</span>
          <p class="text-xs text-brand-muted mt-1 leading-snug">Defined deliverables and measurable milestones</p>
        </div>
        <div class="why-forge-card">
          <div class="trust-icon">
            <svg class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 18L9 11.25l4.306 4.307a11.95 11.95 0 015.814-5.519l2.74-1.22m0 0l-5.94-2.28m5.94 2.28l-2.28 5.941" />
            </svg>
          </div>
          <span class="trust-label">Real Results</span>
          <p class="text-xs text-brand-muted mt-1 leading-snug">Documented outcomes, not vague promises</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- THE PROBLEM                                  -->
  <!-- ============================================ -->
  <section id="problem" class="py-20 sm:py-28 bg-brand-bg">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-16">
          <h2 class="font-display text-3xl sm:text-4xl font-bold text-brand-heading leading-tight">
          The Market Won't Wait for You to Figure It Out
        </h2>
        <p class="mt-6 text-lg text-brand-muted leading-relaxed">
          Most operators are overwhelmed by disconnected web, SEO, and content tasks. The ones scaling are running integrated growth systems.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <!-- Pain Point 1 -->
        <div class="pain-card">
          <div class="pain-number">01</div>
          <h3 class="font-display text-xl font-bold text-brand-white mt-4">Invisible on Search</h3>
          <p class="mt-3 text-brand-white/60 text-sm leading-relaxed">
            Your competitors show up first. Every day you're not discoverable, you're losing demand to someone who is.
          </p>
        </div>

        <!-- Pain Point 2 -->
        <div class="pain-card">
          <div class="pain-number">02</div>
          <h3 class="font-display text-xl font-bold text-brand-white mt-4">Activity Without Systems</h3>
          <p class="mt-3 text-brand-white/60 text-sm leading-relaxed">
            You are shipping tactics but not compounding outcomes. Isolated actions do not create consistent pipeline growth.
          </p>
        </div>

        <!-- Pain Point 3 -->
        <div class="pain-card">
          <div class="pain-number">03</div>
          <h3 class="font-display text-xl font-bold text-brand-white mt-4">Spending Without Tracking</h3>
          <p class="mt-3 text-brand-white/60 text-sm leading-relaxed">
            You're paying for ads, a website, maybe even an agency. But can you tell what's actually working?
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- THE FORGE GROWTH SYSTEM                      -->
  <!-- ============================================ -->
  <section id="system" class="system-section">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-16 sm:mb-20">
        <p class="text-brand-secondary font-semibold text-sm uppercase tracking-wider mb-4">The Forge Growth System</p>
        <h2 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-brand-white leading-tight">
          Stop Buying Tactics.<br/>Start Running a System.
        </h2>
        <p class="mt-6 text-lg text-brand-white/60 max-w-2xl mx-auto leading-relaxed">
          The Forge Growth System connects every part of your marketing so nothing works in isolation.
        </p>
      </div>

      <!-- 3-Stage System -->
      <div class="system-stages">
        <!-- Stage 1 -->
        <div class="system-stage">
          <div class="stage-number-wrapper">
            <span class="stage-number">01</span>
          </div>
          <div class="stage-connector"></div>
          <h3 class="font-display text-2xl font-bold text-brand-white mt-6">Be Found</h3>
          <p class="mt-3 text-brand-white/60 leading-relaxed">
            Get discovered on Google, Maps, AI search, and social. SearchForge handles SEO, GBP optimization, citations, and AI visibility.
          </p>
        </div>

        <!-- Stage 2 -->
        <div class="system-stage">
          <div class="stage-number-wrapper">
            <span class="stage-number">02</span>
          </div>
          <div class="stage-connector"></div>
          <h3 class="font-display text-2xl font-bold text-brand-white mt-6">Be Chosen</h3>
          <p class="mt-3 text-brand-white/60 leading-relaxed">
            Turn visitors into customers with content that converts. ContentForge delivers video, social media, and photography that fills seats.
          </p>
        </div>

        <!-- Stage 3 -->
        <div class="system-stage">
          <div class="stage-number-wrapper">
            <span class="stage-number">03</span>
          </div>
          <h3 class="font-display text-2xl font-bold text-brand-white mt-6">Be Remembered</h3>
          <p class="mt-3 text-brand-white/60 leading-relaxed">
            Keep customers coming back with reputation management, reviews, and retention content.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- SERVICES PREVIEW                             -->
  <!-- ============================================ -->
  <section id="services" class="py-20 sm:py-28 bg-brand-bg">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-14">
        <p class="text-brand-secondary font-semibold text-sm uppercase tracking-wider mb-4">What We Build</p>
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-brand-heading leading-tight">
          Every Service Connects. That's the System.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <ServiceCard
          name="SearchForge"
          subtitle="SEO, Google Maps & AI Visibility"
          description="Rank where your customers are searching — Google, Maps, ChatGPT, and beyond."
          href="/services/search-forge/"
          image="/assets/images/gbp-dashboard.jpg"
        />
        <ServiceCard
          name="ContentForge"
          subtitle="Video, Social Media & Photography"
          description="We come to your restaurant. We film. We post. You fill seats."
          href="/services/content-forge/"
          image="/assets/images/hero-food-plating.jpg"
        />
        <a href="/services/web-design/" class="block bg-brand-card rounded-xl overflow-hidden border border-brand-border card-hover">
          <div class="relative h-40 overflow-hidden bg-brand-primary">
            <!-- CSS-only browser mockup -->
            <div class="webforge-mockup">
              <div class="mockup-toolbar">
                <div class="mockup-dot mockup-dot--red"></div>
                <div class="mockup-dot mockup-dot--yellow"></div>
                <div class="mockup-dot mockup-dot--green"></div>
                <div class="mockup-url-bar">yourrestaurant.ca</div>
              </div>
              <div class="mockup-content">
                <div class="mockup-nav"></div>
                <div class="mockup-hero-block"></div>
                <div class="mockup-grid">
                  <div class="mockup-card"></div>
                  <div class="mockup-card"></div>
                  <div class="mockup-card"></div>
                </div>
              </div>
            </div>
          </div>
          <div class="p-6">
            <h3 class="font-display text-xl font-bold text-brand-heading">WebForge</h3>
            <p class="text-sm text-brand-secondary font-medium mt-1">Website Design & Development</p>
            <p class="mt-3 text-sm text-brand-muted leading-relaxed">Fast, beautiful, conversion-optimized websites that work as hard as you do.</p>
            <span class="mt-4 inline-block text-sm font-semibold text-brand-primary">
              Learn more &rarr;
            </span>
          </div>
        </a>
      </div>

      <div class="mt-10 text-center">
        <a href="/services/" class="text-brand-primary font-semibold hover:text-brand-secondary transition-colors">
          See all services &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- RESULTS / SOCIAL PROOF                       -->
  <!-- ============================================ -->
  <section id="results" class="results-section">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="max-w-3xl mx-auto text-center mb-16">
        <p class="text-brand-secondary font-semibold text-sm uppercase tracking-wider mb-4">Proof, Not Promises</p>
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-brand-heading leading-tight">
          Crab Boil Is Our Loudest Success Story
        </h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Metrics -->
        <div>
          <div class="grid grid-cols-2 gap-8 mb-10">
            <MetricCallout value="523K" label="Monthly search opportunity identified for Crab Boil alone" />
            <MetricCallout value="202K" label="Combined followers across 3 Crab Boil locations" />
            <MetricCallout value="+340" suffix="%" label="Google Maps visibility for Crab Boil in 6 months" />
            <MetricCallout value="90-day" label="Action plan included in every Growth Audit" />
          </div>

          <!-- Proof Card (replaces anonymous testimonial) -->
          <div class="proof-card">
            <div class="proof-card-metric">+340% Google Maps visibility in 6 months</div>
            <p class="text-sm text-brand-muted mt-2">From SEO score 28/100 to fully optimized across 3 locations.</p>
            <p class="text-sm font-semibold text-brand-secondary mt-3">Crab Boil — Toronto & Ottawa</p>
          </div>
        </div>

        <!-- Dashboard Image -->
        <div class="results-image-wrapper">
          <img
            src="/assets/images/analytics-dashboard.jpg"
            alt="Analytics dashboard showing growth metrics and engagement data"
            class="results-image"
            loading="lazy"
            width="600"
            height="400"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- CASE STUDY PREVIEW                           -->
  <!-- ============================================ -->
  <section id="case-studies" class="py-20 sm:py-28 bg-brand-bg">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-14">
        <p class="text-brand-secondary font-semibold text-sm uppercase tracking-wider mb-4">Client Work</p>
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-brand-heading leading-tight">
          Selected Client Work
        </h2>
      </div>

      <div class="max-w-3xl mx-auto">
        <div class="case-study-featured">
          <div class="case-study-image-col">
            <img
              src="/assets/images/restaurant-kitchen.jpg"
              alt="Dark moody restaurant kitchen atmosphere"
              class="case-study-image"
              loading="lazy"
              width="480"
              height="320"
            />
          </div>
          <div class="case-study-content-col">
            <CaseStudyCard
              title="Building a Digital Growth Engine for a Multi-Location Seafood Brand"
              client="Crab Boil — Toronto & Ottawa"
              industry="Restaurant"
              logo="/assets/images/crabboil-logo.jpg"
              services={["SearchForge", "ContentForge"]}
              timeframe="6 months"
              href="/case-studies/crab-boil/"
              metrics={[
                { label: 'Maps visibility', value: '+340', suffix: '%' },
                { label: 'Search opportunity', value: '523K' },
              ]}
            />
          </div>
        </div>
      </div>

      <div class="mt-10 text-center">
        <a href="/case-studies/" class="text-brand-primary font-semibold hover:text-brand-secondary transition-colors">
          See our work &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- GROWTH AUDIT CTA                             -->
  <!-- ============================================ -->
  <!-- ============================================ -->
  <!-- GROWTH AUDIT CTA                             -->
  <!-- ============================================ -->
  <section id="cta-banner" class="bg-brand-dark py-16 sm:py-20">
    <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Text -->
        <div class="text-center lg:text-left">
          <h2 class="font-display text-3xl sm:text-4xl font-bold text-brand-white text-shadow-forge">
            Start With a Growth Audit
          </h2>
          <p class="mt-4 text-lg text-brand-white/70 max-w-xl">
            We audit your Google presence, social media, website, and reviews, then deliver a practical 90-day action plan.
          </p>
          <div class="mt-8 flex flex-col sm:flex-row items-center lg:items-start gap-4">
            <a href="/growth-audit/" class="btn-secondary text-base px-8 py-3">
              Book Your Growth Audit
            </a>
            <a href="/contact/" class="text-brand-white/80 hover:text-brand-white text-base font-medium transition-colors">
              Have questions? Let's talk
            </a>
          </div>
        </div>
        <!-- Audit Preview Card -->
        <div class="audit-preview">
          <div class="audit-preview-header">
            <div class="audit-preview-dot"></div>
            <div class="audit-preview-dot audit-preview-dot--yellow"></div>
            <div class="audit-preview-dot audit-preview-dot--green"></div>
            <span class="audit-preview-title">Growth Audit Report</span>
          </div>
          <div class="audit-preview-body">
            <div class="audit-preview-item">
              <svg class="audit-check" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              <span>Google Business Profile</span>
              <span class="audit-score audit-score--high">92/100</span>
            </div>
            <div class="audit-preview-item">
              <svg class="audit-check" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              <span>Website SEO</span>
              <span class="audit-score audit-score--mid">67/100</span>
            </div>
            <div class="audit-preview-item">
              <svg class="audit-check" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              <span>Social Presence</span>
              <span class="audit-score audit-score--low">41/100</span>
            </div>
            <div class="audit-preview-item">
              <svg class="audit-check" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" /></svg>
              <span>Review Health</span>
              <span class="audit-score audit-score--mid">58/100</span>
            </div>
            <div class="audit-preview-footer">
              <span class="text-brand-secondary font-semibold text-sm">90-Day Action Plan Included</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- BLOG PREVIEW                                 -->
  <!-- ============================================ -->
  <section id="blog" class="py-20 sm:py-28 bg-brand-bg">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
