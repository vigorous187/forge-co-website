---
import Layout from '../layouts/Layout.astro';
import BreadcrumbNav from '../components/BreadcrumbNav.astro';
import FAQ from '../components/FAQ.astro';
import CTABanner from '../components/CTABanner.astro';

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'ContactPage',
    name: 'Contact Forge',
    description: 'Get in touch with Forge. Questions, partnerships, press, or anything else we can help with.',
    url: 'https://forge-co.ca/contact/',
    mainEntity: {
      '@type': 'LocalBusiness',
      name: 'Forge',
      email: 'hello@forge-co.ca',
      address: {
        '@type': 'PostalAddress',
        addressLocality: 'Toronto',
        addressRegion: 'ON',
        addressCountry: 'CA',
      },
      openingHours: 'Mo-Fr 09:00-18:00',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://forge-co.ca/' },
      { '@type': 'ListItem', position: 2, name: 'Contact' },
    ],
  },
];

const faqItems = [
  {
    question: 'How quickly can you start?',
    answer: 'After your Growth Audit, we can typically begin within 1-2 weeks.',
  },
  {
    question: 'Do you work with businesses outside Toronto?',
    answer: 'We primarily serve the Greater Toronto Area, and we can support restaurant teams anywhere in Ontario.',
  },
  {
    question: "What's the minimum commitment?",
    answer: 'Our retainer packages have a 6-month minimum. The Growth Audit is a one-time engagement with no commitment.',
  },
  {
    question: 'Can I just get social media management?',
    answer: "We can, but we'd recommend at least discussing the full Growth System approach first. Disconnected tactics are why most restaurant marketing fails.",
  },
];

const socialLinks = [
  { label: 'Instagram', href: 'https://instagram.com/forgegrowth', icon: 'instagram' },
  { label: 'TikTok', href: 'https://tiktok.com/@forgegrowth', icon: 'tiktok' },
  { label: 'LinkedIn', href: 'https://linkedin.com/company/forge-growth', icon: 'linkedin' },
];

const tallyContactUrl = 'https://tally.so/r/Ek8Q0B?source=forge-contact-page';
---

<Layout
  title="Contact Forge"
  description="Get in touch with Forge. Questions, partnerships, press, or anything else we can help with. For new business, start with a Growth Audit."
  schema={schema}
>
  <!-- Hero -->
  <section id="hero" class="bg-brand-primary section-hero">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center">
      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-800 text-brand-white leading-tight text-shadow-forge">
        Get in Touch
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-brand-white/70 max-w-2xl mx-auto">
        Questions, partnerships, or press. For new business, start with a <a href="/growth-audit/" class="text-brand-secondary hover:underline">Growth Audit</a>.
      </p>
    </div>
  </section>

  <!-- Breadcrumb -->
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-4">
    <BreadcrumbNav items={[{ label: 'Home', href: '/' }, { label: 'Contact' }]} />
  </div>

  <!-- Contact Form + Info -->
  <section id="contact-form" class="section-standard">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-5 gap-10 xl:gap-12 items-start">
        <!-- Form (3 cols) -->
        <div class="lg:col-span-3">
          <h2 class="font-display text-2xl font-bold text-brand-heading mb-4">Send Us a Message</h2>
          <p class="text-sm text-brand-muted mb-6 max-w-2xl">
            Contact submissions are handled through our Tally intake and synced to Notion for follow-up.
          </p>
          <div class="rounded-2xl border border-brand-border overflow-hidden bg-brand-card shadow-sm">
            <div class="border-b border-brand-border bg-brand-bg-alt px-5 py-3">
              <p class="text-xs uppercase tracking-wider font-semibold text-brand-muted">Forge Intake Form</p>
            </div>
            <iframe
              src={tallyContactUrl}
              title="Forge Contact Form"
              loading="lazy"
              class="w-full min-h-[700px]"
            ></iframe>
          </div>
          <a href={tallyContactUrl} target="_blank" rel="noopener noreferrer" class="btn-secondary mt-4 inline-block text-base px-8 py-3">
            Open Form in New Tab
          </a>
        </div>

        <!-- Contact Info (2 cols) -->
        <div class="lg:col-span-2 lg:sticky lg:top-24">
          <h2 class="font-display text-2xl font-bold text-brand-heading mb-8">Get in Touch</h2>
          <div class="space-y-6 rounded-2xl border border-brand-border bg-brand-card p-6">
            <div>
              <h3 class="text-sm font-semibold uppercase tracking-wider text-brand-muted mb-2">Email</h3>
              <a href="mailto:hello@forge-co.ca" class="text-brand-heading hover:text-brand-secondary transition-colors font-medium">
                hello@forge-co.ca
              </a>
            </div>
            <div>
              <h3 class="text-sm font-semibold uppercase tracking-wider text-brand-muted mb-2">Location</h3>
              <p class="text-brand-heading font-medium">Toronto, ON</p>
            </div>
            <div>
              <h3 class="text-sm font-semibold uppercase tracking-wider text-brand-muted mb-2">Hours</h3>
              <p class="text-brand-heading font-medium">Mon-Fri, 9am-6pm EST</p>
            </div>
            <div>
              <h3 class="text-sm font-semibold uppercase tracking-wider text-brand-muted mb-2">Social</h3>
              <div class="flex items-center gap-4 mt-2">
                {socialLinks.map((social) => (
                  <a
                    href={social.href}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="text-brand-muted hover:text-brand-secondary transition-colors"
                    aria-label={social.label}
                  >
                    {social.icon === 'instagram' && (
                      <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z" />
                      </svg>
                    )}
                    {social.icon === 'tiktok' && (
                      <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12.525.02c1.31-.02 2.61-.01 3.91-.02.08 1.53.63 3.09 1.75 4.17 1.12 1.11 2.7 1.62 4.24 1.79v4.03c-1.44-.05-2.89-.35-4.2-.97-.57-.26-1.1-.59-1.62-.93-.01 2.92.01 5.84-.02 8.75-.08 1.4-.54 2.79-1.35 3.94-1.31 1.92-3.58 3.17-5.91 3.21-1.43.08-2.86-.31-4.08-1.03-2.02-1.19-3.44-3.37-3.65-5.71-.02-.5-.03-1-.01-1.49.18-1.9 1.12-3.72 2.58-4.96 1.66-1.44 3.98-2.13 6.15-1.72.02 1.48-.04 2.96-.04 4.44-.99-.32-2.15-.23-3.02.37-.63.41-1.11 1.04-1.36 1.75-.21.51-.15 1.07-.14 1.61.24 1.64 1.82 3.02 3.5 2.87 1.12-.01 2.19-.66 2.77-1.61.19-.33.4-.67.41-1.06.1-1.79.06-3.57.07-5.36.01-4.03-.01-8.05.02-12.07z" />
                      </svg>
                    )}
                    {social.icon === 'linkedin' && (
                      <svg class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z" />
                      </svg>
                    )}
                  </a>
                ))}
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section id="faq" class="section-standard bg-brand-bg-alt">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-3xl sm:text-4xl font-bold text-brand-heading text-center mb-12">
        Frequently Asked Questions
      </h2>
      <FAQ items={faqItems} />
    </div>
  </section>

  <!-- CTA Banner -->
  <CTABanner
    headline="Not ready for a call? Start with a Growth Audit."
    description="A complete diagnostic of your digital presence and a 90-day plan to fix it."
    primaryCTA={{ text: 'Get Your Growth Audit', href: '/growth-audit/' }}
  />
</Layout>
