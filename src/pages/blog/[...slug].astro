---
import Layout from '../../layouts/Layout.astro';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';
import BlogCard from '../../components/BlogCard.astro';
import CTABanner from '../../components/CTABanner.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);

// Get related posts (same category, exclude current)
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const relatedPosts = allPosts
  .filter((p) => p.id !== post.id && p.data.category === post.data.category)
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime())
  .slice(0, 3);

const formattedDate = post.data.publishDate.toLocaleDateString('en-CA', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const categoryLabels: Record<string, string> = {
  'seo': 'SEO',
  'social-media': 'Social Media',
  'restaurant-marketing': 'Restaurant Marketing',
  'local-business': 'Local Business',
  'industry-trends': 'Industry Trends',
  'case-study': 'Case Study',
  'strategy': 'Strategy',
};

/** Must match files in public/assets/team/ (same paths as /about). */
const authorPhotos: Record<string, string> = {
  'Michael Sifontes': '/assets/team/michael-sifontes.jpg',
  'Jayden Aj': '/assets/team/jayden-aj.png',
};

const defaultAuthorPhoto = '/assets/team/michael-sifontes.jpg';

const authorBios: Record<string, string> = {
  'Michael Sifontes': 'Michael is the co-founder of Forge and the architect behind The Forge Growth System. He builds the marketing infrastructure that turns visibility into revenue for GTA restaurants.',
  'Jayden Aj': 'Jayden is the co-founder of Forge and leads client relationships and content strategy. He brings a content-creator perspective to restaurant marketing, with a focus on social media and video production.',
};

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Blog', href: '/blog/' },
  { label: post.data.title },
];

// Table of contents from H2 headings
const tocItems = headings.filter((h) => h.depth === 2);

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: post.data.title,
    description: post.data.description,
    author: {
      '@type': 'Person',
      name: post.data.author,
      image: `https://forge-co.ca${authorPhotos[post.data.author] ?? defaultAuthorPhoto}`,
    },
    publisher: {
      '@type': 'Organization',
      name: 'Forge',
      url: 'https://forge-co.ca',
    },
    datePublished: post.data.publishDate.toISOString(),
    dateModified: (post.data.updatedDate || post.data.publishDate).toISOString(),
    image: post.data.featuredImage ? `https://forge-co.ca${post.data.featuredImage}` : undefined,
    mainEntityOfPage: post.data.canonical || `https://forge-co.ca/blog/${post.id}/`,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbs.map((item, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: item.label,
      item: item.href ? `https://forge-co.ca${item.href}` : undefined,
    })),
  },
];

if (post.data.faq && post.data.faq.length > 0) {
  schema.push({
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: post.data.faq.map((item) => ({
      '@type': 'Question',
      name: item.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: item.answer,
      },
    })),
  });
}
---

<Layout
  title={`${post.data.title} | Forge`}
  description={post.data.description}
  ogType="article"
  canonicalUrl={post.data.canonical || `https://forge-co.ca/blog/${post.id}/`}
  schema={schema}
>
  <!-- Hero -->
  <section class="bg-brand-primary section-hero">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="mb-6">
        <BreadcrumbNav items={breadcrumbs} />
      </div>
      <span class="inline-block px-3 py-1 text-xs uppercase font-semibold tracking-wider text-brand-primary bg-brand-secondary rounded-full mb-4">
        {categoryLabels[post.data.category] || post.data.category}
      </span>
      <h1 class="font-display text-3xl sm:text-4xl lg:text-5xl font-bold text-brand-white text-shadow-forge leading-tight">
        {post.data.title}
      </h1>
      <div class="mt-6 flex items-center gap-4">
        <img
          src={authorPhotos[post.data.author] ?? defaultAuthorPhoto}
          alt={post.data.author}
          class="h-12 w-12 rounded-full object-cover border-2 border-brand-secondary"
          width="48"
          height="48"
          loading="eager"
          fetchpriority="high"
        />
        <div>
          <p class="text-brand-white font-medium">{post.data.author}</p>
          <p class="text-brand-white/60 text-sm">{formattedDate} &middot; {post.data.readTime} min read</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Featured Image -->
  {post.data.featuredImage && (
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 -mt-8">
      <img
        src={post.data.featuredImage}
        alt={post.data.title}
        class="w-full rounded-xl shadow-lg"
      />
    </div>
  )}

  <!-- Content + TOC -->
  <section class="section-compact">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="flex gap-12 lg:gap-16">
        <!-- Main Content -->
        <div class="flex-1 max-w-3xl mx-auto lg:mx-0">
          <!-- Table of Contents -->
          {tocItems.length > 2 && (
            <nav
              class="mb-10 rounded-xl border border-brand-border bg-brand-card p-6 shadow-sm ring-1 ring-black/5 border-l-4 border-l-brand-secondary"
              aria-label="In this article"
            >
              <h2 class="font-display text-sm font-bold text-brand-heading uppercase tracking-wider mb-4">In This Article</h2>
              <ul class="space-y-2">
                {tocItems.map((item) => (
                  <li>
                    <a
                      href={`#${item.slug}`}
                      class="text-sm text-brand-muted hover:text-brand-primary transition-colors"
                    >
                      {item.text}
                    </a>
                  </li>
                ))}
              </ul>
            </nav>
          )}

          <!-- Article Body -->
          <article
            class="prose prose-lg max-w-none
            prose-headings:font-display prose-headings:text-brand-heading prose-headings:scroll-mt-24
            prose-p:text-brand-text prose-p:leading-relaxed
            prose-a:text-brand-secondary prose-a:font-medium prose-a:no-underline hover:prose-a:underline
            prose-strong:text-brand-heading
            prose-li:text-brand-text prose-li:marker:text-brand-secondary
            prose-ul:text-brand-text
            prose-ol:text-brand-text
            prose-blockquote:border-brand-secondary prose-blockquote:text-brand-muted prose-blockquote:not-italic
            prose-h2:text-2xl prose-h2:mt-12 prose-h2:mb-4 prose-h2:pb-2 prose-h2:border-b prose-h2:border-brand-border
            prose-h3:text-xl prose-h3:mt-8 prose-h3:mb-3
          ">
            <Content />
          </article>

          <!-- Author Bio -->
          <div class="mt-16 p-6 bg-brand-bg-alt rounded-xl border border-brand-border flex gap-6 items-start">
            <img
              src={authorPhotos[post.data.author] ?? defaultAuthorPhoto}
              alt={post.data.author}
              class="h-16 w-16 rounded-full object-cover flex-shrink-0 border-2 border-brand-border"
              width="64"
              height="64"
              loading="lazy"
            />
            <div>
              <p class="font-display font-bold text-brand-heading">{post.data.author}</p>
              <p class="mt-1 text-sm text-brand-muted leading-relaxed">
                {authorBios[post.data.author] || ''}
              </p>
              <p class="mt-3 text-xs text-brand-muted">
                Last reviewed by {post.data.lastReviewedBy} on {post.data.reviewedDate.toLocaleDateString('en-CA', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}.
              </p>
            </div>
          </div>

          <!-- Tags -->
          {post.data.tags.length > 0 && (
            <div class="mt-8 flex flex-wrap gap-2">
              {post.data.tags.map((tag) => (
                <span class="inline-block px-3 py-1 bg-brand-primary/5 text-brand-primary text-xs font-medium rounded-full">
                  #{tag}
                </span>
              ))}
            </div>
          )}

          <section class="mt-10 p-6 bg-brand-bg-alt rounded-xl border border-brand-border">
            <h2 class="font-display text-xl font-bold text-brand-heading mb-3">Sources</h2>
            <ul class="space-y-2 list-disc pl-5">
              {post.data.sources.map((source) => (
                <li class="text-sm text-brand-muted">
                  <a href={source.url} target="_blank" rel="nofollow noopener noreferrer" class="text-brand-primary hover:underline">
                    {source.name}
                  </a>
                  {' '}({source.publisher}, {source.date})
                </li>
              ))}
            </ul>
          </section>

          {post.data.faq && post.data.faq.length > 0 && (
            <section class="mt-10 p-6 bg-brand-bg-alt rounded-xl border border-brand-border">
              <h2 class="font-display text-xl font-bold text-brand-heading mb-4">Frequently Asked Questions</h2>
              <div class="space-y-4">
                {post.data.faq.map((item) => (
                  <div>
                    <h3 class="font-semibold text-brand-heading">{item.question}</h3>
                    <p class="text-sm text-brand-muted mt-1">{item.answer}</p>
                  </div>
                ))}
              </div>
            </section>
          )}
        </div>
      </div>
    </div>
  </section>

  <!-- Related Posts -->
  {relatedPosts.length > 0 && (
    <section class="section-compact bg-brand-bg-alt">
      <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
        <h2 class="font-display text-2xl font-bold text-brand-heading mb-8">Related Articles</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
          {relatedPosts.map((related) => (
            <BlogCard
              title={related.data.title}
              description={related.data.description}
              date={related.data.publishDate}
              category={related.data.category}
              image={related.data.featuredImage}
              href={`/blog/${related.id}/`}
              readTime={related.data.readTime}
            />
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <CTABanner
    headline="Ready to grow your restaurant?"
    description="Get a complete marketing audit for your restaurant. We'll show you exactly what's working, what's not, and what to do next."
    primaryCTA={{ text: 'Get Your Growth Audit', href: '/growth-audit/' }}
  />
</Layout>
