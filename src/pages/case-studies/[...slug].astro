---
import Layout from '../../layouts/Layout.astro';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';
import MetricCallout from '../../components/MetricCallout.astro';
import TestimonialCard from '../../components/TestimonialCard.astro';
import CTABanner from '../../components/CTABanner.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const caseStudies = await getCollection('caseStudies');
  return caseStudies.map((study) => ({
    params: { slug: study.id },
    props: { study },
  }));
}

const { study } = Astro.props;
const { Content } = await render(study);

const breadcrumbs = [
  { label: 'Home', href: '/' },
  { label: 'Case Studies', href: '/case-studies/' },
  { label: study.data.client },
];

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'Article',
    headline: study.data.title,
    author: {
      '@type': 'Organization',
      name: 'Forge',
    },
    publisher: {
      '@type': 'Organization',
      name: 'Forge',
      url: 'https://forge-co.ca',
    },
    datePublished: study.data.publishDate.toISOString(),
    description: `Case study: ${study.data.title}`,
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: breadcrumbs.map((item, index) => ({
      '@type': 'ListItem',
      position: index + 1,
      name: item.label,
      item: item.href ? `https://forge-co.ca${item.href}` : undefined,
    })),
  },
];
---

<Layout
  title={`${study.data.title} | Forge`}
  description={`Case study: How Forge helped ${study.data.client} grow with ${study.data.services.join(' and ')}.`}
  schema={schema}
>
  <!-- Hero -->
  <section class="bg-brand-primary section-hero relative overflow-hidden">
    {study.data.featuredImage && (
      <div class="absolute inset-0 z-0">
        <img
          src={study.data.featuredImage}
          alt=""
          class="w-full h-full object-cover opacity-15"
        />
        <div class="absolute inset-0 bg-gradient-to-b from-brand-primary/80 to-brand-primary"></div>
      </div>
    )}
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="mb-6">
        <BreadcrumbNav items={breadcrumbs} />
      </div>
      <span class="inline-block text-xs uppercase font-semibold tracking-wider text-brand-secondary mb-4">
        {study.data.industry}
      </span>
      <h1 class="font-display text-3xl sm:text-5xl font-bold text-brand-white text-shadow-forge max-w-4xl">
        {study.data.title}
      </h1>
      <p class="mt-4 text-lg text-brand-white/70">
        {study.data.client} &middot; {study.data.location}
      </p>
    </div>
  </section>

  <!-- Key Metrics -->
  <section class="section-compact bg-brand-bg-alt">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8">
        {study.data.metrics.map((metric) => (
          <MetricCallout
            value={metric.value}
            label={metric.label}
            prefix={metric.prefix}
            suffix={metric.suffix}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Content -->
  <section class="py-16 sm:py-20">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <div class="prose prose-lg max-w-none
        prose-headings:font-display prose-headings:text-brand-heading
        prose-p:text-brand-text prose-p:leading-relaxed
        prose-a:text-brand-secondary prose-a:no-underline hover:prose-a:underline
        prose-strong:text-brand-heading
        prose-li:text-brand-text
        prose-ul:text-brand-text
      ">
        <Content />
      </div>
    </div>
  </section>

  <!-- Testimonial -->
  {study.data.testimonial && (
    <section class="section-compact bg-brand-bg-alt">
      <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
        <h2 class="font-display text-2xl font-bold text-brand-heading mb-6 text-center">What They Said</h2>
        <TestimonialCard
          quote={study.data.testimonial.quote}
          author={study.data.testimonial.author}
          role={study.data.testimonial.role}
        />
      </div>
    </section>
  )}

  <!-- Services Used -->
  <section class="section-compact">
    <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8">
      <h2 class="font-display text-2xl font-bold text-brand-heading mb-6">Services Used</h2>
      <div class="flex flex-wrap gap-3">
        {study.data.services.map((service) => (
          <span class="inline-block px-4 py-2 bg-brand-primary/10 text-brand-primary text-sm font-semibold rounded-full">
            {service}
          </span>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <CTABanner
    headline="Ready to build your growth system?"
    description="Every engagement starts with a Growth Audit. We'll map out exactly where the opportunities are for your business."
    primaryCTA={{ text: 'Get Your Growth Audit', href: '/growth-audit/' }}
    secondaryCTA={{ text: 'View All Case Studies', href: '/case-studies/' }}
  />
</Layout>
