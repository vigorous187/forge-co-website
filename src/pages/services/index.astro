---
import Layout from '../../layouts/Layout.astro';
import BreadcrumbNav from '../../components/BreadcrumbNav.astro';
import ServiceCard from '../../components/ServiceCard.astro';
import CTABanner from '../../components/CTABanner.astro';

const schema = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebPage',
    name: 'Services — The Forge Growth System',
    description: 'Connected marketing services for GTA restaurants. SEO, content, web design, and reputation management — all working together as one growth system.',
    url: 'https://forge-co.ca/services/',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://forge-co.ca/' },
      { '@type': 'ListItem', position: 2, name: 'Services' },
    ],
  },
];

const stages = [
  {
    number: '01',
    name: 'Be Found',
    description: 'Get discovered on Google, Maps, AI search, and social media. Visibility is the foundation — if customers can\'t find you, nothing else matters.',
  },
  {
    number: '02',
    name: 'Be Chosen',
    description: 'Turn visitors into customers with a website that converts, content that builds trust, and a brand presence that stands out from competitors.',
  },
  {
    number: '03',
    name: 'Be Remembered',
    description: 'Keep customers coming back with reputation management, review systems, and retention content that turns one-time visitors into regulars.',
  },
];
---

<Layout
  title="Services — The Forge Growth System | Forge"
  description="Connected marketing services for GTA restaurants. SEO, content, web design, and reputation management — all working together as one growth system."
  schema={schema}
>

  <!-- ============================================ -->
  <!-- HERO                                         -->
  <!-- ============================================ -->
  <section id="hero" class="bg-brand-primary section-hero relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-brand-primary to-brand-dark/30 pointer-events-none"></div>
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 text-center relative z-10">
      <div class="mb-6">
        <BreadcrumbNav items={[
          { label: 'Home', href: '/' },
          { label: 'Services' },
        ]} />
      </div>
      <p class="text-brand-secondary font-semibold text-sm uppercase tracking-wider mb-4">The Forge Growth System</p>
      <h1 class="font-display text-4xl sm:text-5xl lg:text-6xl font-800 text-brand-white leading-tight text-shadow-forge">
        The Forge Growth System
      </h1>
      <p class="mt-6 text-lg sm:text-xl text-brand-white/70 max-w-2xl mx-auto leading-relaxed">
        Connected marketing that turns visibility into revenue. Every service works together — that's the system.
      </p>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- THE SYSTEM VISUAL                            -->
  <!-- ============================================ -->
  <section id="system" class="section-hero bg-brand-bg">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <h2 class="sr-only">How the growth system connects</h2>
      <div class="system-stages">
        {stages.map((stage) => (
          <div class="system-stage">
            <div class="stage-number-wrapper">
              <span class="stage-number">{stage.number}</span>
            </div>
            <div class="stage-connector"></div>
            <h3 class="font-display text-2xl font-bold text-brand-heading mt-6">{stage.name}</h3>
            <p class="mt-3 text-brand-muted leading-relaxed">{stage.description}</p>
          </div>
        ))}
      </div>
      <p class="mt-16 text-center text-lg text-brand-text font-medium max-w-2xl mx-auto">
        This isn't a menu of tactics. It's a connected system where every piece amplifies the others.
      </p>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- SERVICE CARDS                                -->
  <!-- ============================================ -->
  <section id="services" class="section-hero bg-white">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-14">
        <p class="text-brand-secondary font-semibold text-sm uppercase tracking-wider mb-4">Our Services</p>
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-brand-heading leading-tight">
          Every Service Connects. That's the System.
        </h2>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
        <ServiceCard
          name="SearchForge"
          subtitle="SEO, Google Maps & AI Visibility"
          description="Rank where your customers are searching — Google, Maps, ChatGPT, and beyond. Local SEO, organic search, and AI citation optimization."
          href="/services/search-forge/"
        />
        <ServiceCard
          name="ContentForge"
          subtitle="Video, Social Media & Photography"
          description="We come to your restaurant. We film. We post. You fill seats. On-site video, social management, and brand photography."
          href="/services/content-forge/"
        />
        <ServiceCard
          name="WebForge"
          subtitle="Website Design & Development"
          description="Fast, beautiful, conversion-optimized websites that work as hard as you do. Built for speed, SEO, and mobile."
          href="/services/web-design/"
        />
      </div>

      <!-- Coming Soon: ReviewForge -->
      <div class="mt-6 grid grid-cols-1 md:grid-cols-3 gap-6">
        <div class="md:col-start-2">
          <div class="bg-brand-card rounded-xl p-6 border border-brand-border opacity-70 relative">
            <span class="absolute top-4 right-4 text-xs font-semibold text-brand-secondary bg-brand-secondary/10 px-2 py-1 rounded-full">
              Coming Soon
            </span>
            <h3 class="font-display text-xl font-bold text-brand-heading">ReviewForge</h3>
            <p class="text-sm text-brand-secondary font-medium mt-1">Reviews, Reputation & Response Systems</p>
            <p class="mt-3 text-sm text-brand-muted leading-relaxed">
              Automated review generation, AI-assisted responses, and multi-platform reputation monitoring.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- WHY A SYSTEM WORKS                           -->
  <!-- ============================================ -->
  <section id="why-system" class="section-hero bg-brand-bg">
    <div class="mx-auto max-w-6xl px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl mx-auto text-center mb-14">
        <h2 class="font-display text-3xl sm:text-4xl font-bold text-brand-heading leading-tight">
          Why a System Works
        </h2>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16">
        <div>
          <h3 class="font-display text-xl font-bold text-brand-heading mb-4">The Problem with "Services"</h3>
          <p class="text-brand-muted leading-relaxed text-lg">
            Most agencies sell you a list of services. You pick social media, or SEO, or a new website. Each one operates in a silo. Results are inconsistent because nothing connects.
          </p>
        </div>
        <div>
          <h3 class="font-display text-xl font-bold text-brand-heading mb-4">The Forge Difference</h3>
          <p class="text-brand-muted leading-relaxed text-lg">
            Forge connects every channel into one growth engine. Your SEO drives traffic to a website that converts. Your content builds the reputation that SEO rewards. Your reviews fuel the trust that content creates. That's the system.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================ -->
  <!-- CTA BANNER                                   -->
  <!-- ============================================ -->
  <CTABanner
    headline="See what's broken. Get it fixed."
    description="A complete diagnostic of your digital presence with a 90-day plan to fix it."
    primaryCTA={{ text: 'Get Your Growth Audit', href: '/growth-audit/' }}
  />

</Layout>

<style>
  /* ===== SYSTEM STAGES ===== */
  .system-stages {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }

  @media (min-width: 768px) {
    .system-stages {
      grid-template-columns: repeat(3, 1fr);
      gap: 2rem;
    }
  }

  .system-stage {
    position: relative;
    text-align: center;
    padding: 2rem 1.5rem;
  }

  .stage-number-wrapper {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 4rem;
    height: 4rem;
    border-radius: 9999px;
    background: rgba(196, 154, 60, 0.15);
    border: 2px solid var(--color-brand-secondary);
  }

  .stage-number {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 800;
    color: var(--color-brand-secondary);
  }

  .stage-connector {
    display: none;
  }

  @media (min-width: 768px) {
    .stage-connector {
      display: block;
      position: absolute;
      top: 2rem;
      left: calc(50% + 2.5rem);
      width: calc(100% - 2rem);
      height: 2px;
      background: linear-gradient(90deg, var(--color-brand-secondary), rgba(196, 154, 60, 0.2));
      transform: translateY(calc(2rem - 1px));
    }

    .system-stage:last-child .stage-connector {
      display: none;
    }
  }
</style>
